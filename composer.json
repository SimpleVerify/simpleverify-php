{
    "name": "simpleverify/simpleverify-php",
    "description": "PHP client library for the SimpleVerify API - developer-first verification alerts (SMS, email, magic link)",
    "type": "library",
    "license": "MIT",
    "keywords": ["simpleverify", "verification", "sms", "email", "magic-link", "otp", "2fa"],
    "homepage": "https://simpleverify.com",
    "require": {
        "php": "^8.1",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "SimpleVerify\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SimpleVerify\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
